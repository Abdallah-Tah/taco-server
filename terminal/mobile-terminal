#!/usr/bin/env bash
set -e
SESSION="mobile"
START="/home/abdaltm86/Documents/taco-servers/terminal/taco-menu"

# ttyd sometimes launches in a way where plain tmux attach/new-session complains
# about not having a terminal. Prefer a resilient fallback so the terminal is
# always usable.
if command -v tmux >/dev/null 2>&1; then
  if [ -t 0 ] || [ -t 1 ] || [ -t 2 ]; then
    exec tmux new-session -A -s "$SESSION" "$START"
  fi
fi

# Fallback: run the menu directly so the web terminal is never blank.
exec "$START"
